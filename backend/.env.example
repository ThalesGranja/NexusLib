# Porta em que o servidor Express vai rodar
PORT=5000

# String de conexao do MongoDB (local ou Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/nexuslib

# Segredo usado para assinar os tokens JWT (troque por um valor seguro)
JWT_SECRET=troque-este-valor-por-uma-string-secreta-grande

# Ambiente de execucao
NODE_ENV=development
